+func TestConvertGeminiResponseToOpenAIResponses_RestoresCodexToolKindsAndNamespaces(t *testing.T) {
+	request := []byte(`{
+		"model":"gemini-3-flash-agent",
+		"input":[{
+			"type":"additional_tools",
+			"tools":[
+				{"type":"custom","name":"apply_patch"},
+				{"type":"namespace","name":"collaboration","tools":[{"type":"function","name":"send_message","parameters":{"type":"object"}}]}
+			]
+		}]
+	}`)
+	in := []string{
+		`data: {"response":{"candidates":[{"content":{"role":"model","parts":[{"functionCall":{"name":"apply_patch","args":{"input":"*** Begin Patch"},"id":"call_patch"}}]}}],"modelVersion":"test-model","responseId":"req_tools"}}`,
+		`data: {"response":{"candidates":[{"content":{"role":"model","parts":[{"functionCall":{"name":"collaboration__send_message","args":{"target":"worker"},"id":"call_send"}}]}}],"modelVersion":"test-model","responseId":"req_tools"}}`,
+		`data: {"response":{"candidates":[{"content":{"role":"model","parts":[{"text":""}]},"finishReason":"STOP"}],"modelVersion":"test-model","responseId":"req_tools"}}`,
+	}
+
+	var param any
+	var out [][]byte
+	for _, line := range in {
+		out = append(out, ConvertGeminiResponseToOpenAIResponses(context.Background(), "test-model", request, nil, []byte(line), &param)...)
+	}
+
+	var customAdded, customInputDone, customDone, functionAdded, functionDone, completed gjson.Result
+	for _, chunk := range out {
+		event, data := parseSSEEvent(t, chunk)
+		switch event {
+		case "response.output_item.added":
+			switch data.Get("item.type").String() {
+			case "custom_tool_call":
+				customAdded = data
+			case "function_call":
+				functionAdded = data
+			}
+		case "response.custom_tool_call_input.done":
+			customInputDone = data
+		case "response.output_item.done":
+			switch data.Get("item.type").String() {
+			case "custom_tool_call":
+				customDone = data
+			case "function_call":
+				functionDone = data
+			}
+		case "response.function_call_arguments.delta", "response.function_call_arguments.done":
+			if data.Get("item_id").String() == "ctc_call_patch" {
+				t.Fatalf("custom tool emitted function argument event: %s", chunk)
+			}
+		case "response.completed":
+			completed = data
+		}
+	}
+
+	for _, got := range []gjson.Result{customAdded, customDone} {
+		if !got.Exists() {
+			t.Fatal("missing custom tool event")
+		}
+		if name := got.Get("item.name").String(); name != "apply_patch" {
+			t.Fatalf("custom tool name = %q, want apply_patch", name)
+		}
+		if callID := got.Get("item.call_id").String(); callID != "call_patch" {
+			t.Fatalf("custom tool call_id = %q, want call_patch", callID)
+		}
+	}
+	if got := customInputDone.Get("input").String(); got != "*** Begin Patch" {
+		t.Fatalf("custom input done = %q", got)
+	}
+	if got := customDone.Get("item.input").String(); got != "*** Begin Patch" {
+		t.Fatalf("custom done input = %q", got)
+	}
+
+	for _, got := range []gjson.Result{functionAdded, functionDone} {
+		if !got.Exists() {
+			t.Fatal("missing namespace function event")
+		}
+		if name := got.Get("item.name").String(); name != "send_message" {
+			t.Fatalf("namespace function name = %q, want send_message", name)
+		}
+		if namespace := got.Get("item.namespace").String(); namespace != "collaboration" {
+			t.Fatalf("namespace = %q, want collaboration", namespace)
+		}
+		if callID := got.Get("item.call_id").String(); callID != "call_send" {
+			t.Fatalf("namespace function call_id = %q, want call_send", callID)
+		}
+	}
+
+	if got := completed.Get("response.output.0.type").String(); got != "custom_tool_call" {
+		t.Fatalf("completed output[0].type = %q, want custom_tool_call", got)
+	}
+	if got := completed.Get("response.output.0.input").String(); got != "*** Begin Patch" {
+		t.Fatalf("completed custom input = %q", got)
+	}
+	if got := completed.Get("response.output.1.name").String(); got != "send_message" {
+		t.Fatalf("completed namespace name = %q", got)
+	}
+	if got := completed.Get("response.output.1.namespace").String(); got != "collaboration" {
+		t.Fatalf("completed namespace = %q", got)
+	}
+}
