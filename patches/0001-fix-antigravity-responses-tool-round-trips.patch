+func TestConvertOpenAIResponsesRequestToAntigravity_ConvertsCodexAdditionalTools(t *testing.T) {
+	raw := []byte(`{
+		"input":[
+			{"type":"additional_tools","role":"developer","tools":[
+				{"type":"custom","name":"apply_patch","description":"Apply a patch"},
+				{"type":"function","name":"read_file","parameters":{"type":"object","properties":{"path":{"type":"string"}},"required":["path"]}},
+				{"type":"namespace","name":"collaboration","tools":[{"type":"function","name":"send_message","parameters":{"type":"object"}}]}
+			]},
+			{"role":"user","content":[{"type":"input_text","text":"fix the bug"}]}
+		]
+	}`)
+
+	for _, model := range []string{"claude-opus-4-6-thinking", "gemini-3-flash-agent"} {
+		t.Run(model, func(t *testing.T) {
+			out := ConvertOpenAIResponsesRequestToAntigravity(model, raw, true)
+			declarations := gjson.GetBytes(out, "request.tools.0.functionDeclarations").Array()
+			if len(declarations) != 3 {
+				t.Fatalf("function declaration count = %d, want 3. Output: %s", len(declarations), out)
+			}
+			byName := make(map[string]gjson.Result, len(declarations))
+			for _, declaration := range declarations {
+				byName[declaration.Get("name").String()] = declaration
+			}
+			if got := byName["apply_patch"].Get("parametersJsonSchema.required.0").String(); got != "input" {
+				t.Fatalf("custom declaration input schema missing. Output: %s", out)
+			}
+			if got := byName["read_file"].Get("parametersJsonSchema.required.0").String(); got != "path" {
+				t.Fatalf("function declaration schema missing. Output: %s", out)
+			}
+			if _, exists := byName["collaboration__send_message"]; !exists {
+				t.Fatalf("namespace declaration missing. Output: %s", out)
+			}
+			if strings.Contains(string(out), "additional_tools") {
+				t.Fatalf("additional_tools leaked to Antigravity upstream. Output: %s", out)
+			}
+		})
+	}
+}
