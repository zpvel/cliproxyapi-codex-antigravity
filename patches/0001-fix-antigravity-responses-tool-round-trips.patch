+func TestOpenAIResponsesToolNameMaps_DisambiguatesLongCollisions(t *testing.T) {
+	root := gjson.Parse(`{
+		"input":[{"type":"additional_tools","tools":[
+			{"type":"function","name":"mcp__plugin_cloudflare_cloudflare-builds__workers_builds_get_build"},
+			{"type":"function","name":"mcp__plugin_cloudflare_cloudflare-builds__workers_builds_get_build_logs"}
+		]}]
+	}`)
+	tools := collectOpenAIResponsesTools(root)
+	forward, reverse := openAIResponsesToolNameMaps(tools)
+	if len(forward) != 2 || len(reverse) != 2 {
+		t.Fatalf("map sizes = %d/%d, want 2/2", len(forward), len(reverse))
+	}
+	first := forward[tools[0].QualifiedName]
+	second := forward[tools[1].QualifiedName]
+	if first == "" || second == "" || first == second {
+		t.Fatalf("mapped names = %q and %q, want distinct non-empty names", first, second)
+	}
+	if len(first) > 64 || len(second) > 64 {
+		t.Fatalf("mapped name lengths = %d and %d, want <= 64", len(first), len(second))
+	}
+	if reverse[first] != tools[0].QualifiedName || reverse[second] != tools[1].QualifiedName {
+		t.Fatalf("reverse map did not restore original names: %v", reverse)
+	}
+}
