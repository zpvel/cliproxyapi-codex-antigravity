@@ -0,0 +1,239 @@
+package responses
+
+import (
+	"strings"
+
+	"github.com/router-for-me/CLIProxyAPI/v7/internal/util"
+	"github.com/tidwall/gjson"
+	"github.com/tidwall/sjson"
+)
+
+type openAIResponsesToolKind string
+
+const (
+	openAIResponsesFunctionTool openAIResponsesToolKind = "function"
+	openAIResponsesCustomTool   openAIResponsesToolKind = "custom"
+)
+
+type openAIResponsesTool struct {
+	Kind          openAIResponsesToolKind
+	Name          string
+	Namespace     string
+	QualifiedName string
+	Description   string
+	Parameters    gjson.Result
+}
+
+func openAIResponsesRequestRoot(rawJSON []byte) gjson.Result {
+	root := gjson.ParseBytes(rawJSON)
+	request := root.Get("request")
+	if request.Exists() && (request.Get("input").Exists() || request.Get("tools").Exists()) {
+		return request
+	}
+	return root
+}
+
+func collectOpenAIResponsesTools(root gjson.Result) []openAIResponsesTool {
+	var tools []openAIResponsesTool
+	var collect func(gjson.Result, string)
+	collect = func(toolArray gjson.Result, namespace string) {
+		if !toolArray.IsArray() {
+			return
+		}
+		toolArray.ForEach(func(_, tool gjson.Result) bool {
+			kind := strings.TrimSpace(tool.Get("type").String())
+			switch kind {
+			case "namespace":
+				nestedNamespace := strings.TrimSpace(tool.Get("name").String())
+				if namespace != "" {
+					nestedNamespace = qualifyOpenAIResponsesToolName(namespace, nestedNamespace)
+				}
+				collect(tool.Get("tools"), nestedNamespace)
+			case "", "function", "custom":
+				name := openAIResponsesToolName(tool)
+				if name == "" {
+					return true
+				}
+				qualifiedName := qualifyOpenAIResponsesToolName(namespace, name)
+				toolKind := openAIResponsesFunctionTool
+				if kind == "custom" {
+					toolKind = openAIResponsesCustomTool
+				}
+				tools = append(tools, openAIResponsesTool{
+					Kind:          toolKind,
+					Name:          name,
+					Namespace:     namespace,
+					QualifiedName: qualifiedName,
+					Description:   openAIResponsesToolDescription(tool),
+					Parameters:    openAIResponsesToolParameters(tool),
+				})
+			}
+			return true
+		})
+	}
+
+	collect(root.Get("tools"), "")
+	if input := root.Get("input"); input.IsArray() {
+		input.ForEach(func(_, item gjson.Result) bool {
+			if item.Get("type").String() == "additional_tools" {
+				collect(item.Get("tools"), "")
+			}
+			return true
+		})
+	}
+	return tools
+}
+
+func openAIResponsesToolName(tool gjson.Result) string {
+	if name := strings.TrimSpace(tool.Get("name").String()); name != "" {
+		return name
+	}
+	return strings.TrimSpace(tool.Get("function.name").String())
+}
+
+func openAIResponsesToolDescription(tool gjson.Result) string {
+	if description := tool.Get("description").String(); description != "" {
+		return description
+	}
+	return tool.Get("function.description").String()
+}
+
+func openAIResponsesToolParameters(tool gjson.Result) gjson.Result {
+	for _, path := range []string{
+		"parameters",
+		"parametersJsonSchema",
+		"input_schema",
+		"function.parameters",
+		"function.parametersJsonSchema",
+	} {
+		if parameters := tool.Get(path); parameters.Exists() {
+			return parameters
+		}
+	}
+	return gjson.Result{}
+}
+
+func qualifyOpenAIResponsesToolName(namespace, name string) string {
+	namespace = strings.TrimSpace(namespace)
+	name = strings.TrimSpace(name)
+	if namespace == "" || name == "" || strings.HasPrefix(name, "mcp__") {
+		return name
+	}
+	if strings.HasPrefix(name, namespace) {
+		return name
+	}
+	if strings.HasSuffix(namespace, "__") {
+		return namespace + name
+	}
+	return namespace + "__" + name
+}
+
+func openAIResponsesToolNameMaps(tools []openAIResponsesTool) (map[string]string, map[string]string) {
+	if len(tools) == 0 {
+		return nil, nil
+	}
+
+	synthetic := []byte(`{"tools":[]}`)
+	seen := make(map[string]struct{}, len(tools))
+	for _, tool := range tools {
+		if tool.QualifiedName == "" {
+			continue
+		}
+		if _, exists := seen[tool.QualifiedName]; exists {
+			continue
+		}
+		seen[tool.QualifiedName] = struct{}{}
+		declaration := []byte(`{"name":""}`)
+		declaration, _ = sjson.SetBytes(declaration, "name", tool.QualifiedName)
+		synthetic, _ = sjson.SetRawBytes(synthetic, "tools.-1", declaration)
+	}
+
+	forward := util.SanitizedFunctionNameMap(synthetic)
+	if len(forward) == 0 {
+		return nil, nil
+	}
+	reverse := make(map[string]string, len(forward))
+	for original, sanitized := range forward {
+		reverse[sanitized] = original
+	}
+	return forward, reverse
+}
+
+func openAIResponsesToolByQualifiedName(tools []openAIResponsesTool, qualifiedName string) (openAIResponsesTool, bool) {
+	for _, tool := range tools {
+		if tool.QualifiedName == qualifiedName {
+			return tool, true
+		}
+	}
+	return openAIResponsesTool{}, false
+}
+
+func restoreOpenAIResponsesToolName(reverse map[string]string, upstreamName string) string {
+	if original := reverse[upstreamName]; original != "" {
+		return original
+	}
+	return upstreamName
+}
+
+func openAIResponsesInputToolName(item gjson.Result) string {
+	name := strings.TrimSpace(item.Get("name").String())
+	if namespace := strings.TrimSpace(item.Get("namespace").String()); namespace != "" {
+		name = qualifyOpenAIResponsesToolName(namespace, name)
+	}
+	return name
+}
+
+func wrapOpenAIResponsesCustomToolInput(input string) string {
+	wrapper, _ := sjson.SetBytes([]byte(`{"input":""}`), "input", input)
+	return string(wrapper)
+}
+
+func unwrapOpenAIResponsesCustomToolInput(arguments string) string {
+	if input := gjson.Get(arguments, "input"); input.Exists() {
+		if input.Type == gjson.String {
+			return input.String()
+		}
+		return input.Raw
+	}
+	return arguments
+}
+
+func openAIResponsesToolOutputText(output gjson.Result) string {
+	if output.Type == gjson.String {
+		return output.String()
+	}
+	if output.IsArray() {
+		var text strings.Builder
+		output.ForEach(func(_, part gjson.Result) bool {
+			if part.Type == gjson.String {
+				text.WriteString(part.String())
+				return true
+			}
+			if value := part.Get("text"); value.Exists() {
+				text.WriteString(value.String())
+			}
+			return true
+		})
+		return text.String()
+	}
+	if output.Exists() {
+		return output.Raw
+	}
+	return ""
+}
+
+func applyOpenAIResponsesFunctionIdentity(item []byte, tool openAIResponsesTool, itemPath string) []byte {
+	namePath := "name"
+	namespacePath := "namespace"
+	if itemPath != "" {
+		namePath = itemPath + ".name"
+		namespacePath = itemPath + ".namespace"
+	}
+	item, _ = sjson.SetBytes(item, namePath, tool.Name)
+	if tool.Namespace != "" {
+		item, _ = sjson.SetBytes(item, namespacePath, tool.Namespace)
+	} else {
+		item, _ = sjson.DeleteBytes(item, namespacePath)
+	}
+	return item
+}
