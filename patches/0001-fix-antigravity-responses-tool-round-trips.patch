+func TestConvertOpenAIResponsesRequestToGemini_ConvertsCodexAdditionalTools(t *testing.T) {
+	input := []byte(`{
+		"model":"gemini-3-flash-agent",
+		"input":[
+			{
+				"type":"additional_tools",
+				"role":"developer",
+				"tools":[
+					{"type":"custom","name":"apply_patch","description":"Apply a patch","format":{"type":"grammar","syntax":"lark","definition":"start: /.+/"}},
+					{"type":"function","name":"read_file","description":"Read a file","strict":true,"parameters":{"type":"object","properties":{"path":{"type":"string"}},"required":["path"]}},
+					{"type":"namespace","name":"collaboration","tools":[{"type":"function","name":"send_message","parameters":{"type":"object","properties":{"target":{"type":"string"}}}}]}
+				]
+			},
+			{"role":"user","content":[{"type":"input_text","text":"fix the bug"}]}
+		]
+	}`)
+
+	output := ConvertOpenAIResponsesRequestToGemini("gemini-3-flash-agent", input, true)
+	declarations := gjson.GetBytes(output, "tools.0.functionDeclarations").Array()
+	if len(declarations) != 3 {
+		t.Fatalf("function declaration count = %d, want 3. Output: %s", len(declarations), output)
+	}
+
+	byName := make(map[string]gjson.Result, len(declarations))
+	for _, declaration := range declarations {
+		byName[declaration.Get("name").String()] = declaration
+	}
+	if got := byName["apply_patch"].Get("parametersJsonSchema.required.0").String(); got != "input" {
+		t.Fatalf("custom tool required parameter = %q, want input. Output: %s", got, output)
+	}
+	if got := byName["apply_patch"].Get("parametersJsonSchema.properties.input.type").String(); got != "string" {
+		t.Fatalf("custom tool input type = %q, want string. Output: %s", got, output)
+	}
+	if got := byName["read_file"].Get("parametersJsonSchema.required.0").String(); got != "path" {
+		t.Fatalf("function schema was not preserved. Output: %s", output)
+	}
+	if _, ok := byName["collaboration__send_message"]; !ok {
+		t.Fatalf("namespace function declaration missing. Output: %s", output)
+	}
+	if strings.Contains(string(output), "additional_tools") {
+		t.Fatalf("additional_tools input item leaked upstream. Output: %s", output)
+	}
+}
