+func TestConvertOpenAIResponsesRequestToGemini_ReplaysCustomToolCallAndOutput(t *testing.T) {
+	input := []byte(`{
+		"input":[
+			{"type":"additional_tools","tools":[{"type":"custom","name":"apply_patch"}]},
+			{"role":"user","content":[{"type":"input_text","text":"fix it"}]},
+			{"type":"custom_tool_call","call_id":"call_patch","name":"apply_patch","input":"*** Begin Patch"},
+			{"type":"custom_tool_call_output","call_id":"call_patch","output":[{"type":"input_text","text":"Done!"}]},
+			{"role":"user","content":[{"type":"input_text","text":"continue"}]}
+		]
+	}`)
+
+	output := ConvertOpenAIResponsesRequestToGemini("gemini-3-flash-agent", input, true)
+	functionCall := gjson.GetBytes(output, "contents.1.parts.0.functionCall")
+	if got := functionCall.Get("name").String(); got != "apply_patch" {
+		t.Fatalf("function call name = %q, want apply_patch. Output: %s", got, output)
+	}
+	if got := functionCall.Get("id").String(); got != "call_patch" {
+		t.Fatalf("function call id = %q, want call_patch. Output: %s", got, output)
+	}
+	if got := functionCall.Get("args.input").String(); got != "*** Begin Patch" {
+		t.Fatalf("wrapped custom input = %q. Output: %s", got, output)
+	}
+	functionResponse := gjson.GetBytes(output, "contents.2.parts.0.functionResponse")
+	if got := functionResponse.Get("name").String(); got != "apply_patch" {
+		t.Fatalf("function response name = %q, want apply_patch. Output: %s", got, output)
+	}
+	if got := functionResponse.Get("id").String(); got != "call_patch" {
+		t.Fatalf("function response id = %q, want call_patch. Output: %s", got, output)
+	}
+	if got := functionResponse.Get("response.result").String(); got != "Done!" {
+		t.Fatalf("custom output = %q, want Done!. Output: %s", got, output)
+	}
+}
