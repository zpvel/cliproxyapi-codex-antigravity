+package responses
+
+import (
+	"context"
+	"testing"
+
+	"github.com/tidwall/gjson"
+)
+
+func TestConvertAntigravityResponseToOpenAIResponsesNonStream_PreservesOriginalResponsesTools(t *testing.T) {
+	originalRequest := []byte(`{
+		"model":"claude-opus-4-6-thinking",
+		"input":[{"type":"additional_tools","tools":[
+			{"type":"custom","name":"apply_patch"},
+			{"type":"namespace","name":"collaboration","tools":[{"type":"function","name":"send_message"}]}
+		]}]
+	}`)
+	translatedRequest := []byte(`{"model":"claude-opus-4-6-thinking","request":{"contents":[],"tools":[{"functionDeclarations":[{"name":"apply_patch"},{"name":"collaboration__send_message"}]}]}}`)
+	upstreamResponse := []byte(`{"response":{"responseId":"req_antigravity_tools","candidates":[{"content":{"role":"model","parts":[
+		{"functionCall":{"name":"apply_patch","args":{"input":"patch text"},"id":"call_patch"}},
+		{"functionCall":{"name":"collaboration__send_message","args":{"target":"worker"},"id":"call_send"}}
+	]}}]}}`)
+
+	response := ConvertAntigravityResponseToOpenAIResponsesNonStream(
+		context.Background(),
+		"claude-opus-4-6-thinking",
+		originalRequest,
+		translatedRequest,
+		upstreamResponse,
+		nil,
+	)
+	result := gjson.ParseBytes(response)
+	if got := result.Get("output.0.type").String(); got != "custom_tool_call" {
+		t.Fatalf("output[0].type = %q, want custom_tool_call. Response: %s", got, response)
+	}
+	if got := result.Get("output.0.input").String(); got != "patch text" {
+		t.Fatalf("output[0].input = %q, want patch text", got)
+	}
+	if got := result.Get("output.0.call_id").String(); got != "call_patch" {
+		t.Fatalf("output[0].call_id = %q, want call_patch", got)
+	}
+	if got := result.Get("output.1.name").String(); got != "send_message" {
+		t.Fatalf("output[1].name = %q, want send_message", got)
+	}
+	if got := result.Get("output.1.namespace").String(); got != "collaboration" {
+		t.Fatalf("output[1].namespace = %q, want collaboration", got)
+	}
+	if got := result.Get("output.1.call_id").String(); got != "call_send" {
+		t.Fatalf("output[1].call_id = %q, want call_send", got)
+	}
+}
+
+func TestConvertAntigravityResponseToOpenAIResponsesNonStream_UnwrapsWrappedOriginalRequest(t *testing.T) {
+	originalRequest := []byte(`{"request":{"model":"gemini-3-flash-agent","input":[{"type":"additional_tools","tools":[{"type":"custom","name":"apply_patch"}]}]}}`)
+	upstreamResponse := []byte(`{"response":{"responseId":"req_wrapped","candidates":[{"content":{"role":"model","parts":[{"functionCall":{"name":"apply_patch","args":{"input":"wrapped patch"},"id":"call_wrapped"}}]}}]}}`)
+
+	response := ConvertAntigravityResponseToOpenAIResponsesNonStream(
+		context.Background(),
+		"gemini-3-flash-agent",
+		originalRequest,
+		nil,
+		upstreamResponse,
+		nil,
+	)
+	result := gjson.ParseBytes(response)
+	if got := result.Get("output.0.type").String(); got != "custom_tool_call" {
+		t.Fatalf("output[0].type = %q, want custom_tool_call. Response: %s", got, response)
+	}
+	if got := result.Get("output.0.input").String(); got != "wrapped patch" {
+		t.Fatalf("output[0].input = %q, want wrapped patch", got)
+	}
+}
