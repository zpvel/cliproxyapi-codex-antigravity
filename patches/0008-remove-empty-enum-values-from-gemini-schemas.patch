diff --git a/internal/util/gemini_schema.go b/internal/util/gemini_schema.go
index 010669a..c09e55b 100644
--- a/internal/util/gemini_schema.go
+++ b/internal/util/gemini_schema.go
@@ -49,6 +49,7 @@ func cleanJSONSchema(jsonStr string, addPlaceholder bool) string {
 		// Gemini schema cleanup: remove nullable/title and placeholder-only fields.
 		jsonStr = removeKeywords(jsonStr, []string{"nullable", "title"})
 		jsonStr = removePlaceholderFields(jsonStr)
+		jsonStr = removeEmptyEnumValues(jsonStr)
 	}
 	jsonStr = cleanupRequiredFields(jsonStr)
 	// Phase 4: Add placeholder for empty object schemas (Claude VALIDATED mode requirement)
@@ -211,6 +212,36 @@ func convertEnumValuesToStrings(jsonStr string) string {
 	return jsonStr
 }
 
+// removeEmptyEnumValues removes enum members rejected by the Gemini API. Some
+// Codex tool schemas use an empty string as a UI sentinel, but Gemini requires
+// every enum value to be non-empty.
+func removeEmptyEnumValues(jsonStr string) string {
+	paths := findPaths(jsonStr, "enum")
+	sortByDepth(paths)
+	for _, p := range paths {
+		enum := gjson.Get(jsonStr, p)
+		if !enum.IsArray() {
+			continue
+		}
+
+		values := make([]string, 0, len(enum.Array()))
+		for _, value := range enum.Array() {
+			if value.String() != "" {
+				values = append(values, value.String())
+			}
+		}
+		if len(values) == 0 {
+			jsonStr, _ = sjson.Delete(jsonStr, p)
+			continue
+		}
+		if len(values) != len(enum.Array()) {
+			updated, _ := sjson.SetBytes([]byte(jsonStr), p, values)
+			jsonStr = string(updated)
+		}
+	}
+	return jsonStr
+}
