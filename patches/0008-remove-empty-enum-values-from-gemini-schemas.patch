diff --git a/internal/util/gemini_schema_test.go b/internal/util/gemini_schema_test.go
index bb581cd..237d7cf 100644
--- a/internal/util/gemini_schema_test.go
+++ b/internal/util/gemini_schema_test.go
@@ -940,6 +940,36 @@ func TestCleanJSONSchemaForGemini_RemovesGeminiUnsupportedMetadataFields(t *test
 	compareJSON(t, expected, result)
 }
 
+func TestCleanJSONSchemaForGemini_RemovesEmptyEnumValuesRecursively(t *testing.T) {
+	input := `{
+		"type": "object",
+		"properties": {
+			"status": {"type": "string", "enum": ["ready", "", "failed"]},
+			"empty_only": {"type": "string", "enum": [""]},
+			"rows": {
+				"type": "array",
+				"items": {
+					"type": "object",
+					"properties": {
+						"align": {"type": "string", "enum": ["left", "", "right"]}
+					}
+				}
+			}
+		}
+	}`
+
+	result := CleanJSONSchemaForGemini(input)
+	if got := gjson.Get(result, "properties.status.enum").Array(); len(got) != 2 || got[0].String() != "ready" || got[1].String() != "failed" {
+		t.Fatalf("status enum = %s, want ready/failed", gjson.Get(result, "properties.status.enum").Raw)
+	}
+	if gjson.Get(result, "properties.empty_only.enum").Exists() {
+		t.Fatalf("empty-only enum should be removed: %s", result)
+	}
+	if got := gjson.Get(result, "properties.rows.items.properties.align.enum").Array(); len(got) != 2 || got[0].String() != "left" || got[1].String() != "right" {
+		t.Fatalf("nested enum = %s, want left/right", gjson.Get(result, "properties.rows.items.properties.align.enum").Raw)
+	}
+}
